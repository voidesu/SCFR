// Implementação: Validação de Data
int validarData(Data dt) {
    if (dt.dia >= 1 && dt.dia <= 30) {
        if (dt.mes >= 1 && dt.mes <= 12) {
            if (dt.ano >= 1900 && dt.ano <= 2026) {
                return 1;
            }
        }
    }
    return 0;
}

// Implementação: Validação de CPF
int validarCPF(Cliente c) {
    j = 10;
    soma = 0;
    int resto = 0, primeiroDigito = 0, segundoDigito = 0;
        
    for(i = 0; i < 20; i++) {
        if(c.CPF[i] == '\0') break;
        if(c.CPF[i] == '.' || c.CPF[i] == '-') continue;
            
        soma += (c.CPF[i] - '0') * j;
        j--;
        if(j < 2) break;
    }
    
    resto = (soma * 10) % 11;
    primeiroDigito = (resto > 10) ? 0 : resto;
    
    j = 11;
    soma = 0;
    
    for(i = 0; i < 20; i++) {
        if(c.CPF[i] == '\0') break;
        if(c.CPF[i] == '.' || c.CPF[i] == '-') continue;
            
        soma += (c.CPF[i] - '0') * j;
        j--;
        if(j < 2) break;
    }
    
    resto = (soma * 10) % 11;
    segundoDigito = (resto > 10) ? 0 : resto;
    
    int tam = strlen(c.CPF);
    if ((c.CPF[tam - 1] - '0' == segundoDigito) && (c.CPF[tam - 2] - '0' == primeiroDigito)) {
        printf("Resultado: CPF Validado!\n");
        return 0;
    } else {
        printf("Resultado: CPF Invalido!\n");
        return 1;
    }
}

// Implementação: Calcular Parcela
int CalcularParcela() {
    float valorTotal = 0;
    int qtdParcelas = 0;
    Parcela p;
    
    printf("Qual seria o valor total da venda? R$ ");
    scanf("%f", &valorTotal);
    printf("Quantas parcelas? ");
    scanf("%d", &qtdParcelas);
    
    if (qtdParcelas <= 0) {
        printf("Quantidade de parcelas invalida!\n");
        return 1;
    }
    
    p.numeroDaParcela = qtdParcelas;
    p.valorDaParcela = valorTotal / qtdParcelas;
    
    printf("Valor de cada parcela (%d vezes): R$ %.2f\n", p.numeroDaParcela, p.valorDaParcela);
    return 0;
}

// Implementação: Exibir Parcela
void exibirParcela(Parcela p) {
    printf("        Dados da Parcela   \n");
    printf("ID da Parcela      ->  %10d\n", p.idParcela);
    printf("ID da Venda        ->  %10d\n", p.idVenda);
    printf("Numero da Parcela  ->  %10d\n", p.numeroDaParcela);
    printf("Valor da Parcela   ->  R$ %7.2f\n", p.valorDaParcela);
    printf("Data de Vencimento ->  %02d/%02d/%d\n", p.dataVencimento.dia, p.dataVencimento.mes, p.dataVencimento.ano);
    printf("Data de Recebimento -> %02d/%02d/%d\n", p.dataRecebimento.dia, p.dataRecebimento.mes, p.dataRecebimento.ano);
    printf("\nSituacao da Parcela: %c\n", p.situacaoDaParcela);
}
